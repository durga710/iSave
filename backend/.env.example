# Neon serverless Postgres — copy connection string from Neon dashboard
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/isave?sslmode=require

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# Plaid — get from https://dashboard.plaid.com
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_or_production_secret
# sandbox | development | production
PLAID_ENV=sandbox

PORT=3000
